<?xml version="1.0" encoding="utf-8"?>
<!--
  Sent message — bubble flush to right edge.

  Root is horizontal LinearLayout:
    Space (weight=1) — fills all leftover space, pushes bubble right
    Bubble (wrap_content, maxWidth=280dp) — sits flush at right

  This is the WhatsApp/Signal/Telegram pattern. Simple and correct.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <!-- Spacer pushes bubble to the right -->
    <Space
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <!-- Bubble — wraps content, capped at 280dp -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_sent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tvMessageContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:id="@+id/tvMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</LinearLayout>